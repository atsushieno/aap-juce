diff --git a/modules/juce_gui_basics/menus/juce_PopupMenu.cpp b/modules/juce_gui_basics/menus/juce_PopupMenu.cpp
--- a/modules/juce_gui_basics/menus/juce_PopupMenu.cpp
+++ b/modules/juce_gui_basics/menus/juce_PopupMenu.cpp
@@ -368,9 +368,29 @@ struct MenuWindow final : public Component
             if (shouldDisableAccessibility)
                 setAccessible (false);
 
-            addToDesktop (ComponentPeer::windowIsTemporary
-                          | ComponentPeer::windowIgnoresKeyPresses
-                          | lf.getMenuWindowFlags());
-
+#if JUCE_ANDROID
+            {
+                // setOpaque must precede addToDesktop on Android: if the peer already
+                // exists when setOpaque is called it calls addToDesktop again without
+                // the native handle, crashing in SurfaceControlViewHost contexts.
+                setOpaque (lf.findColour (PopupMenu::backgroundColourId).isOpaque()
+                           || ! Desktop::canUseSemiTransparentWindows());
+                Component* parentComp = options.getParentComponent();
+                if (parentComp == nullptr) parentComp = parent;
+                if (parentComp == nullptr) parentComp = options.getTargetComponent();
+                void* nativeHandle = nullptr;
+                if (parentComp != nullptr)
+                    if (auto* peer = parentComp->getTopLevelComponent()->getPeer())
+                        nativeHandle = peer->getNativeHandle();
+                addToDesktop (ComponentPeer::windowIsTemporary
+                              | ComponentPeer::windowIgnoresKeyPresses
+                              | lf.getMenuWindowFlags(), nativeHandle);
+            }
+#else
+            addToDesktop (ComponentPeer::windowIsTemporary
+                          | ComponentPeer::windowIgnoresKeyPresses
+                          | lf.getMenuWindowFlags());
+#endif
+
             Desktop::getInstance().addGlobalMouseListener (this);
         }
