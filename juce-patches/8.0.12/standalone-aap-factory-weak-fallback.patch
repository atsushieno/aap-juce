+// JUCE_USE_CUSTOM_PLUGIN_STANDALONE_APP=1 but never invokes
+// START_JUCE_APPLICATION (so JUCE_CREATE_APPLICATION_DEFINE never expands).
+// Declared weak so a strong definition emitted by the patched
+// JUCE_CREATE_APPLICATION_DEFINE macro still wins when present.
+#if JUCE_ANDROID
+ extern "C" void* GetJuceAAPFactory();
+ extern "C" __attribute((visibility("default"))) __attribute((weak))
+ void* GetJuceAAPFactoryStandalone() { return GetJuceAAPFactory(); }
